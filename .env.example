# ==============================================================================
# Public Procurement Policy System — 환경변수 예시 파일
#
# 사용 방법:
#   cp .env.example .env
#   .env 파일을 열어 실제 값으로 수정합니다.
#
# 주의:
#   .env 파일은 .gitignore에 포함되어 있어 Git에 커밋되지 않습니다.
#   민감한 정보(API 키, 비밀번호 등)는 반드시 .env에서 관리하세요.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME=Public Procurement Policy System
APP_VERSION=0.1.0

# 실행 환경: development | staging | production
ENVIRONMENT=development

# 디버그 모드: True | False  (운영 환경에서는 반드시 False)
DEBUG=True

# ------------------------------------------------------------------------------
# Path — 값을 지정하지 않으면 프로젝트 루트 아래 기본 경로를 사용합니다.
# ------------------------------------------------------------------------------

# 구매실적 Excel, 수집 데이터 등 데이터 파일 저장 경로
# DATA_PATH=/absolute/path/to/data

# SQLite 데이터베이스 파일 저장 디렉터리
# DATABASE_PATH=/absolute/path/to/database

# SQLite 데이터베이스 파일명 (기본값: procurement.db)
# DATABASE_FILENAME=procurement.db

# 로그 파일 저장 경로
# LOG_PATH=/absolute/path/to/logs